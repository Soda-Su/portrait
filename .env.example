NEXT_PUBLIC_SITE_URL=http://localhost:3003

# Supabase real-beta mode. Leave unset to use the local JSON repository.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
PORTRAY_ADMIN_EMAILS=
PORTRAY_DEMO_PASSPORT_URL=

# Formspree receives a copy of each intake submission.
FORMSPREE_ENDPOINT=

# Set provider to openai for a direct OpenAI API key, or gateway for Vercel AI Gateway.
PORTRAY_AI_MODE=mock
PORTRAY_AI_PROVIDER=openai
PORTRAY_OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=

# Gateway alternative. VERCEL_OIDC_TOKEN can replace AI_GATEWAY_API_KEY on Vercel.
PORTRAY_AI_MODEL=openai/gpt-5-mini
AI_GATEWAY_API_KEY=
PORTRAY_IP_HASH_SALT=change-me
